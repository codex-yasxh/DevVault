



CREATE TABLE TechEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    status TEXT NOT NULL,
    firstUsed TEXT NOT NULL,
    lastUsed TEXT
);

getAllTech:
SELECT * FROM TechEntity ORDER BY firstUsed DESC;

insertTech:
INSERT INTO TechEntity (
    name,
    status,
    firstUsed,
    lastUsed
)
VALUES (?, ?, ?, ?);

updateTechStatus:
UPDATE TechEntity
SET status = :status
WHERE id = :id;

deleteTech:
DELETE FROM TechEntity WHERE id = :id;
